{
  "productName": "Canopi",
  "version": "0.1.0",
  "identifier": "com.canopi.app",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "web"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "web"
    },
    "devUrl": "http://localhost:1420",
    "frontendDist": "web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/image-cache/**"]
      },
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost blob: data: https:",
        "connect-src": "ipc: http://ipc.localhost https:",
        "worker-src": "'self' blob:",
        "font-src": "'self' data:"
      },
      "capabilities": ["main-window"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Canopi",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/canopi-core.db"]
  },
  "plugins": {}
}
