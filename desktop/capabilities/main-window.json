{
  "identifier": "main-window",
  "description": "Main window capabilities for Canopi",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "mcp-bridge:default",
    "process:default",
    "updater:default"
  ]
}
